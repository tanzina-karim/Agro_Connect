rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               data.role in ['farmer', 'buyer', 'transporter', 'admin'];
      }

      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'location', 'phone', 'joinedAt']);
    }

    // --- Products ---
    match /products/{productId} {
      function isValidProduct(data) {
        return data.farmerId == request.auth.uid &&
               data.name is string && data.name.size() > 0 &&
               data.price is number && data.price > 0 &&
               data.unit is string &&
               data.farmerName is string;
      }

      allow read: if true; // Marketplace visibility
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && existing().farmerId == request.auth.uid && isValidProduct(incoming());
      allow delete: if isSignedIn() && existing().farmerId == request.auth.uid;
    }

    // --- Orders ---
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.buyerId is string &&
               data.farmerId is string &&
               data.productId is string &&
               data.quantity is number && data.quantity > 0 &&
               data.totalAmount is number && data.totalAmount > 0 &&
               data.status in ['pending', 'accepted', 'rejected', 'paid', 'shipment_accepted', 'collected', 'shipped', 'delivered'];
      }

      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.farmerId == request.auth.uid || 
        resource.data.transporterId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'transporter'
      );
      
      // Buyer creates
      allow create: if isSignedIn() && 
                    incoming().buyerId == request.auth.uid && 
                    incoming().status == 'pending' &&
                    isValidOrder(incoming());
      
      // Updates based on roles and current status
      allow update: if isSignedIn() && (
        // Farmer Accept/Reject
        (existing().farmerId == request.auth.uid && 
         existing().status == 'pending' && 
         incoming().status in ['accepted', 'rejected'] &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        
        // Buyer Pay
        (existing().buyerId == request.auth.uid && 
         existing().status == 'accepted' && 
         incoming().status == 'paid' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'paymentMethod'])) ||
        
        // Farmer Shipping/Delivery
        (existing().farmerId == request.auth.uid && 
         existing().status == 'paid' && 
         incoming().status in ['shipped', 'delivered'] &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||

        // Transporter Accept Job
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'transporter' &&
         (existing().status == 'accepted' || existing().status == 'paid') &&
         incoming().status == 'shipment_accepted' &&
         incoming().transporterId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'transporterId', 'transporterName', 'transporterPhone'])) ||

        // Transporter Progress Deliveries
        (existing().transporterId == request.auth.uid &&
         existing().status in ['shipment_accepted', 'collected', 'shipped'] &&
         incoming().status in ['collected', 'shipped', 'delivered'] &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }
  }
}
