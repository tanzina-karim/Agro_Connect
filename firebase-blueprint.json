{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a user (farmer, buyer, transporter, admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["farmer", "buyer", "transporter", "admin"] },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Agricultural products listed by farmers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "farmerId": { "type": "string" },
        "farmerName": { "type": "string" },
        "location": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "farmerId", "price", "unit"]
    },
    "Order": {
      "title": "Order",
      "description": "Orders placed by buyers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "farmerId": { "type": "string" },
        "farmerName": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "paid", "shipped", "delivered"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "farmerId", "productId", "quantity", "totalAmount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products for sale"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders between buyers and farmers"
    }
  }
}
